# Albion Tools — Environment Variables

# Server Configuration
NODE_ENV=production
PORT=3000

# API Configuration
ALBION_API_BASE=https://west.albion-online-data.com/api/v2/stats
ALBION_GAMEINFO_API=https://gameinfo.albiononline.com/api/gameinfo
ALBION_RENDER_API=https://render.albiononline.com/v1/item/

# Database
DATABASE_PATH=./data/db.json

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*

# Development
DEBUG=false
