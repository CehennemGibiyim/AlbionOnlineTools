{
  "name": "albion-tools",
  "version": "2.0.0",
  "description": "Comprehensive Albion Online toolkit - Market analysis, crafting calculator, PvP tracker",
  "main": "main.js",
  "homepage": "./",
  "author": "Albion Tools Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "build": {
    "appId": "com.albion.tools",
    "productName": "Albion Online Tools",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "service-worker.js",
      "manifest.json",
      "css/**/*",
      "js/**/*",
      "data/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Albion Online Tools"
    }
  },
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run web\" \"wait-on http://localhost:3000 && electron .\"",
    "web": "node server.js",
    "build-db": "node build-db.js",
    "build": "npm run build-db && electron-builder --win --x64 --publish=never",
    "build:exe": "electron-builder --win --x64 --publish=never",
    "build:portable": "electron-builder --win --x64 --publish=never -c.nsis=false -c.win.target=portable",
    "test": "echo \"Tests not yet implemented\""
  },
  "keywords": [
    "albion-online",
    "craft",
    "market",
    "tools",
    "calculator",
    "desktop-app"
  ],
  "dependencies": {
    "chart.js": "^3.9.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "nodemon": "^3.0.1",
    "wait-on": "^7.2.0"
  }
}
